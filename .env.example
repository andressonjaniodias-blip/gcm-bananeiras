NODE_ENV=development
PORT=3000

# Gere com: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=

# Gere com: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=

DATABASE_URL=postgresql://localhost:5432/gcm_bananeiras
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000
LOG_LEVEL=debug
# Retenção de BOs (anos) — após o prazo podem ser arquivados/eliminados ou anonimizados.
RETENCAO_ANOS=5
# Retenção do log de auditoria (anos) — IP/dispositivo são dado pessoal e têm prazo de guarda.
RETENCAO_LOGS_ANOS=2

# Configuração de e-mail (recuperação de senha, PDFs automáticos) — envio via API da Brevo
# Crie a chave em https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
SMTP_FROM=GCM Bananeiras <noreply@exemplo.gov.br>
APP_URL=http://localhost:3000

# E-mail que recebe automaticamente os PDFs gerados (BO, viatura, escala, férias,
# relatório e fechamento diário de plantões extras).
# LGPD: use uma CAIXA INSTITUCIONAL sob controle do controlador (não um e-mail
# pessoal). Os PDFs contêm dados pessoais; BOs sensíveis são enviados censurados.
NOTIFICACAO_PDF_EMAIL=comando@exemplo.gov.br
