NODE_ENV=development
PORT=3000

# Gere com: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=

# Gere com: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=

DATABASE_URL=postgresql://localhost:5432/gcm_bananeiras
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000
LOG_LEVEL=debug
RETENCAO_ANOS=5

# Configuração de e-mail (recuperação de senha) — envio via API da Brevo
# Crie a chave em https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
SMTP_FROM=GCM Bananeiras <noreply@gcm-bananeiras.onrender.com>
APP_URL=http://localhost:3000
